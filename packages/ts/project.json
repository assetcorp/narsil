{
  "name": "narsil-ts",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm tsup",
        "cwd": "packages/ts"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm vitest run",
        "cwd": "packages/ts"
      }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm vitest run --coverage",
        "cwd": "packages/ts"
      }
    },
    "test:embeddings": {
      "executor": "nx:run-commands",
      "options": {
        "command": "NARSIL_TEST_EMBEDDINGS=1 pnpm vitest run embedding-e2e",
        "cwd": "packages/ts"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm biome check src/",
        "cwd": "packages/ts"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm tsc --noEmit",
        "cwd": "packages/ts"
      }
    },
    "nx-release-publish": {
      "executor": "@nx/js:release-publish"
    }
  }
}
