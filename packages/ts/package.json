{
  "name": "@delali/narsil",
  "version": "0.1.1",
  "type": "module",
  "description": "A distributed full-text search engine with cross-language portable binary format.",
  "author": "Delali (https://sondelali.com)",
  "license": "Apache-2.0",
  "homepage": "https://github.com/assetcorp/narsil",
  "repository": {
    "type": "git",
    "url": "https://github.com/assetcorp/narsil.git",
    "directory": "packages/ts"
  },
  "bugs": {
    "url": "https://github.com/assetcorp/narsil/issues"
  },
  "sideEffects": false,
  "keywords": [
    "search",
    "full-text-search",
    "search-engine",
    "indexing",
    "text-search",
    "distributed",
    "typescript"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    },
    "./adapters/memory": {
      "import": "./dist/adapters/memory.mjs",
      "types": "./dist/adapters/memory.d.ts"
    },
    "./adapters/filesystem": {
      "import": "./dist/adapters/filesystem.mjs",
      "types": "./dist/adapters/filesystem.d.ts"
    },
    "./adapters/indexeddb": {
      "import": "./dist/adapters/indexeddb.mjs",
      "types": "./dist/adapters/indexeddb.d.ts"
    },
    "./invalidation/noop": {
      "import": "./dist/invalidation/noop.mjs",
      "types": "./dist/invalidation/noop.d.ts"
    },
    "./invalidation/filesystem": {
      "import": "./dist/invalidation/filesystem.mjs",
      "types": "./dist/invalidation/filesystem.d.ts"
    },
    "./invalidation/broadcast-channel": {
      "import": "./dist/invalidation/broadcast-channel.mjs",
      "types": "./dist/invalidation/broadcast-channel.d.ts"
    },
    "./languages/*": {
      "import": "./dist/languages/*.mjs",
      "types": "./dist/languages/*.d.ts"
    }
  },
  "files": [
    "dist/",
    "LICENSE"
  ],
  "dependencies": {
    "@msgpack/msgpack": "3.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/node": "22.15.32",
    "@vitest/coverage-v8": "4.0.18",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
