{
  "name": "@delali/narsil",
  "version": "0.1.14",
  "type": "module",
  "description": "A distributed full-text search engine with cross-language portable binary format.",
  "author": "Delali (https://sondelali.com)",
  "license": "Apache-2.0",
  "homepage": "https://github.com/assetcorp/narsil",
  "repository": {
    "type": "git",
    "url": "https://github.com/assetcorp/narsil.git",
    "directory": "packages/ts"
  },
  "bugs": {
    "url": "https://github.com/assetcorp/narsil/issues"
  },
  "imports": {
    "#platform/worker-factory": {
      "browser": "./src/workers/factory.browser.ts",
      "default": "./src/workers/factory.ts"
    },
    "#platform/vector-promoter": {
      "browser": "./src/vector/promoter.browser.ts",
      "default": "./src/vector/promoter.ts"
    },
    "#platform/durable-fs": {
      "browser": "./src/persistence/durability/node-fs.browser.ts",
      "default": "./src/persistence/durability/node-fs.ts"
    },
    "#platform/node-worker": {
      "browser": "./src/workers/node-worker.browser.ts",
      "default": "./src/workers/node-worker.ts"
    }
  },
  "sideEffects": false,
  "keywords": [
    "search",
    "full-text-search",
    "search-engine",
    "indexing",
    "text-search",
    "distributed",
    "typescript"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup && node scripts/check-browser-bundle.mjs",
    "test": "vitest run --exclude='**/vector/recall.test.ts'",
    "test:etcd": "vitest run src/__tests__/distribution/coordinator/etcd-integration/*.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:recall": "vitest run src/__tests__/vector/recall.test.ts",
    "test:embeddings": "NARSIL_TEST_EMBEDDINGS=1 vitest run embedding-e2e",
    "bench": "vitest bench",
    "lint": "biome check src/",
    "typecheck:src": "tsc --noEmit",
    "typecheck:tests": "tsc --noEmit -p tsconfig.test.json",
    "typecheck:tooling": "tsc --noEmit -p scripts/tsconfig.json && tsc --noEmit -p benchmarks/tsconfig.json && tsc --noEmit -p wasm/tsconfig.json",
    "typecheck": "pnpm run typecheck:src && pnpm run typecheck:tests && pnpm run typecheck:tooling"
  },
  "exports": {
    ".": {
      "browser": {
        "import": "./dist/index.browser.mjs",
        "types": "./dist/index.d.ts"
      },
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    },
    "./adapters/memory": {
      "import": "./dist/adapters/memory.mjs",
      "types": "./dist/adapters/memory.d.ts"
    },
    "./adapters/filesystem": {
      "import": "./dist/adapters/filesystem.mjs",
      "types": "./dist/adapters/filesystem.d.ts"
    },
    "./adapters/indexeddb": {
      "import": "./dist/adapters/indexeddb.mjs",
      "types": "./dist/adapters/indexeddb.d.ts"
    },
    "./invalidation/noop": {
      "import": "./dist/invalidation/noop.mjs",
      "types": "./dist/invalidation/noop.d.ts"
    },
    "./invalidation/filesystem": {
      "import": "./dist/invalidation/filesystem.mjs",
      "types": "./dist/invalidation/filesystem.d.ts"
    },
    "./invalidation/broadcast-channel": {
      "import": "./dist/invalidation/broadcast-channel.mjs",
      "types": "./dist/invalidation/broadcast-channel.d.ts"
    },
    "./vector/hnsw-build-worker": {
      "import": "./dist/vector/hnsw-build-worker.mjs",
      "types": "./dist/vector/hnsw-build-worker.d.ts"
    },
    "./embeddings/openai": {
      "import": "./dist/embeddings/openai.mjs",
      "types": "./dist/embeddings/openai.d.ts"
    },
    "./languages/*": {
      "import": "./dist/languages/*.mjs",
      "types": "./dist/languages/*.d.ts"
    },
    "./distribution": {
      "import": "./dist/distribution.mjs",
      "types": "./dist/distribution.d.ts"
    },
    "./distribution/coordinator/in-memory": {
      "import": "./dist/distribution/coordinator/in-memory.mjs",
      "types": "./dist/distribution/coordinator/in-memory.d.ts"
    },
    "./distribution/coordinator/etcd": {
      "import": "./dist/distribution/coordinator/etcd.mjs",
      "types": "./dist/distribution/coordinator/etcd.d.ts"
    },
    "./server": {
      "import": "./dist/server.mjs",
      "types": "./dist/server.d.ts"
    }
  },
  "files": [
    "dist/",
    "LICENSE"
  ],
  "dependencies": {
    "@msgpack/msgpack": "3.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@delali/narsil-embeddings-transformers": "workspace:*",
    "@types/node": "22.15.32",
    "@vitest/coverage-v8": "4.0.18",
    "etcd3": "1.1.2",
    "fflate": "0.8.3",
    "selfsigned": "5.5.0",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.58.0",
    "vitest": "4.0.18",
    "wabt": "1.0.39"
  },
  "peerDependencies": {
    "etcd3": "1.1.2",
    "uWebSockets.js": ">=20.0.0"
  },
  "peerDependenciesMeta": {
    "etcd3": {
      "optional": true
    },
    "uWebSockets.js": {
      "optional": true
    }
  }
}
