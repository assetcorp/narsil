{
  "name": "narsil",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo for narsil, a distributed full-text search engine written in TypeScript.",
  "author": "Delali (https://sondelali.com)",
  "license": "Apache-2.0",
  "homepage": "https://github.com/assetcorp/narsil",
  "repository": {
    "type": "git",
    "url": "https://github.com/assetcorp/narsil.git"
  },
  "bugs": {
    "url": "https://github.com/assetcorp/narsil/issues"
  },
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "test:coverage": "nx run-many -t test:coverage",
    "lint": "nx run-many -t lint",
    "typecheck": "nx run-many -t typecheck",
    "format": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@nx/js": "22.5.4",
    "nx": "22.5.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss",
      "nx"
    ]
  }
}
