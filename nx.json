{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": [],
    "production": [
      "default",
      "!{projectRoot}/**/*.test.ts",
      "!{projectRoot}/**/*.spec.ts",
      "!{projectRoot}/vitest.config.ts"
    ]
  },
  "release": {
    "projects": ["narsil-ts", "narsil-embeddings-transformers", "narsil-certutil"],
    "projectsRelationship": "independent",
    "releaseTagPattern": "{projectName}@v{version}",
    "version": {
      "conventionalCommits": false,
      "updateDependents": "never"
    },
    "changelog": {
      "automaticFromRef": true,
      "workspaceChangelog": {
        "createRelease": "github"
      },
      "projectChangelogs": false
    },
    "git": {
      "commit": true,
      "tag": true,
      "commitMessage": "chore(release): {projectName}@v{version}"
    }
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["production"],
      "outputs": ["{projectRoot}/dist"],
      "cache": true
    },
    "test": {
      "cache": true
    },
    "test:coverage": {
      "cache": true
    },
    "lint": {
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "format": {
      "cache": false
    }
  }
}
